# ---- Testing / coverage ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.cache/

# ---- Linters / type checkers ----
.ruff_cache/
.mypy_cache/
.dmypy.json

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- Data (large / reproducible — not versioned) ----
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ---- ML artifacts ----
# "models/" used to live here for trained artifacts. Unanchored, it matched
# any directory of that name at any depth — and the only one in the repo is
# src/energycast/models, the baseline source code. Artifacts go to the
# artifacts_dir named in configs/base.yaml, which is what is ignored now.
mlruns/
mlartifacts/
artifacts/*
!artifacts/.gitkeep
*.pt
*.pth
*.ckpt
*.joblib
*.pkl
*.onnx

# ---- Logs ----
*.log
logs/

# ---- Secrets / environment ----
.env
.env.*
!.env.example

# ---- Project ----
CLAUDE.md
# Internal work log, not product documentation.
notes/

# ---- IDE / OS ----
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
